# --- SERVER CONFIGURATION ---
NODE_ENV=development
PORT=8000
HOST=0.0.0.0
API_VERSION=1.0.0

# --- GOOGLE CLIENT ID ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- IA - GOOGLE GENERATIVE AI ---
GOOGLE_GENERATIVE_AI_API_KEY=

# --- DATABASE (NEON/POSTGRES) ---
# Se estiver usando o driver neon-serverless com WebSockets, use a connection string comum do Neon
DATABASE_URL=

# --- AUTHENTICATION (BETTER AUTH) ---
BETTER_AUTH_SECRET=
BETTER_AUTH_URL="http://localhost:8000"

# --- SECURITY ---
# Lista de origens permitidas separadas por vírgula (ex: http://localhost:3000,https://meuapp.com)
ALLOWED_ORIGINS="http://localhost:3000"

# --- LOGGING ---
# Nível de log (info, error, debug)
LOG_LEVEL="info"
