{
  "name": "trainify-api",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "scripts": {
    "dev": "tsx --watch --env-file=.env src/server.ts",
    "build": "tsc",
    "start": "node dist/server.ts",
    "drizzle:seed": "tsx src/db/seed.ts",
    "drizzle:migrate": "npx drizzle-kit generate && npx drizzle-kit migrate",
    "drizzle:studio": "npx drizzle-kit studio",
    "drizzle:drop": "npx drizzle-kit drop",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "engines": {
    "node": "24.x"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.30.3",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.4",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@neondatabase/serverless": "^1.0.2",
    "@scalar/fastify-api-reference": "1.44.20",
    "better-auth": "1.5.1",
    "dotenv": "17.3.1",
    "drizzle-orm": "^0.45.1",
    "fastify": "5.7.4",
    "fastify-plugin": "5.1.0",
    "fastify-type-provider-zod": "6.1.0",
